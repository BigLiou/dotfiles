#!/usr/bin/env bash
# run_once_after_00-mise-install.sh.tmpl
# 安装语言运行时环境（配置落盘后执行，仅首次 apply 执行）

set -euo pipefail

# mise 安装到 ~/.local/bin，chezmoi 脚本执行时可能不在 PATH 中
export PATH="$HOME/.local/bin:$PATH"

if ! command -v mise &>/dev/null; then
    echo "⚠️ mise 未安装，跳过运行时安装"
    exit 0
fi

MISE_CONFIG="$HOME/mise.toml"
if [[ ! -f "$MISE_CONFIG" ]]; then
    echo "⚠️ 未检测到 mise.toml，跳过运行时安装"
    exit 0
fi

echo "⏳ 信任 mise 配置..."
mise trust --yes "$MISE_CONFIG"

echo "⏳ 安装语言运行时..."
mise install

echo "✅ 语言运行时安装完成"

# 验证（用 mise which 检测，不需要 mise activate 加载）
echo ""
echo "━━━ 环境验证 ━━━"
for cmd in node python3 java mvn; do
    if mise which "$cmd" &>/dev/null; then
        echo "✅ $cmd 可用"
    else
        echo "⚠️ $cmd 未检测到"
    fi
done
