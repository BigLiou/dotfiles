#!/usr/bin/env bash
# run_once_before_02-install-mise.sh.tmpl
# 安装 mise（仅首次 apply 执行）

set -euo pipefail

if [[ -x "$HOME/.local/bin/mise" ]]; then
    echo "✅ mise 已安装"
    exit 0
fi

echo "⏳ 安装 mise..."
curl -fsSL https://mise.run -o /tmp/mise_install.sh
bash /tmp/mise_install.sh
echo "✅ mise 安装完成"
